# Este archivo es una plantilla. Copialo a backend/.env para arrancar el backend en local.

# Puerto donde escuchara Express.
PORT=4000

# Direccion permitida para el frontend durante el desarrollo local.
CORS_ORIGIN=http://localhost:5175

# Conexion a PostgreSQL local. Cambia usuario, password y puerto segun tu instalacion.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/VibeTrelloCodex

# Secreto para firmar tokens JWT. En produccion debe ser largo y privado.
JWT_SECRET=cambia-este-secreto-en-produccion

# Duracion de la sesion JWT.
JWT_EXPIRES_IN=8h

# Password temporal usada en desarrollo al resetear usuarios.
TEMPORARY_PASSWORD=12345678
