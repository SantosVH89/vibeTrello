# Copia estos valores en el panel de Environment de Dokploy.
# Dokploy crea el .env usado por docker-compose.yml.

# Nombre publico de la aplicacion. Cambialo por tu dominio real.
APP_URL=https://vibetrello.tudominio.com

# Base de datos interna del compose.
POSTGRES_DB=VibeTrelloCodex
POSTGRES_USER=vibetrello
POSTGRES_PASSWORD=cambia-esta-password-larga

# Secreto para firmar sesiones JWT.
# Usa una cadena larga, unica y privada.
JWT_SECRET=cambia-este-secreto-jwt-largo-en-produccion
JWT_EXPIRES_IN=8h

# Password temporal para usuarios creados por admin.
TEMPORARY_PASSWORD=12345678

